<?php
/** @var \SyncEngine\Connector\Block\Adminhtml\DebugPage $block */
$triggerMap = $block->getTriggerMap();
$dispatchLog = $block->getDispatchLog();
$status = $block->escapeHtml($block->getStatus());
?>
<div class="admin__page-section">
    <div class="admin__page-section-title">
        <span class="title">SyncEngine Trigger Debug</span>
    </div>

    <div class="admin__page-section-item">
        <p><strong>SyncEngine API status:</strong> <?= $status ?></p>

        <form action="<?= $block->escapeUrl($block->getRefreshMapUrl()) ?>" method="post" style="display:inline-block; margin-right:10px;">
            <input name="form_key" type="hidden" value="<?= $block->escapeHtmlAttr($block->getFormKey()) ?>" />
            <button type="submit" class="action-primary">
                <span>Refresh Trigger Endpoint Map</span>
            </button>
        </form>

        <form action="<?= $block->escapeUrl($block->getClearLogUrl()) ?>" method="post" style="display:inline-block;">
            <input name="form_key" type="hidden" value="<?= $block->escapeHtmlAttr($block->getFormKey()) ?>" />
            <button type="submit" class="action-secondary">
                <span>Clear Dispatch Log</span>
            </button>
        </form>
    </div>

    <div class="admin__page-section-item" style="margin-top:20px;">
        <h3>Trigger Endpoint Map</h3>
        <pre style="background:#fff; padding:12px; border:1px solid #ddd;"><?= $block->escapeHtml(json_encode($triggerMap, JSON_PRETTY_PRINT)) ?></pre>
    </div>

    <div class="admin__page-section-item" style="margin-top:20px;">
        <h3>Recent Dispatches (latest 50)</h3>
        <?php if (!empty($dispatchLog)): ?>
            <div class="admin__data-grid-wrap admin__data-grid-wrap-static">
                <table class="data-grid">
                    <thead>
                    <tr>
                        <th>Time</th>
                        <th>Source</th>
                        <th>Trigger</th>
                        <th>Endpoint</th>
                        <th>Status</th>
                        <th>Success</th>
                        <th>Payload Size</th>
                        <th>Error</th>
                    </tr>
                    </thead>
                    <tbody>
                    <?php foreach ($dispatchLog as $entry): ?>
                        <tr>
                            <td><?= $block->escapeHtml(date('Y-m-d H:i:s', (int)($entry['timestamp'] ?? 0))) ?></td>
                            <td><?= $block->escapeHtml((string)($entry['source'] ?? '')) ?></td>
                            <td><?= $block->escapeHtml((string)($entry['trigger'] ?? '')) ?></td>
                            <td><?= $block->escapeHtml((string)($entry['endpoint'] ?? '')) ?></td>
                            <td><?= $block->escapeHtml((string)($entry['status'] ?? '')) ?></td>
                            <td><?= !empty($entry['success']) ? 'yes' : 'no' ?></td>
                            <td><?= (int)($entry['payload_size'] ?? 0) ?></td>
                            <td><?= $block->escapeHtml((string)($entry['error'] ?? '')) ?></td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php else: ?>
            <p>No dispatch log entries yet.</p>
        <?php endif; ?>
    </div>
</div>

<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/syncengine/status" method="GET">
        <service class="SyncEngine\Connector\Api\StatusInterface" method="status"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/syncengine/refresh" method="POST">
        <service class="SyncEngine\Connector\Api\RefreshInterface" method="refresh"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
